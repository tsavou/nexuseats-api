{
  "consumer": {
    "name": "front"
  },
  "interactions": [
    {
      "description": "a request for a restaurant by id",
      "providerStates": [
        {
          "name": "a restaurant with id 11111111-1111-4111-8111-111111111111 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/v2/restaurants/11111111-1111-4111-8111-111111111111"
      },
      "response": {
        "body": {
          "data": {
            "address": "12 rue de la Paix, 75002 Paris, FR",
            "cuisine": "ITALIENNE",
            "id": "11111111-1111-4111-8111-111111111111",
            "menus": [
              {
                "id": "22222222-2222-4222-8222-222222222222",
                "name": "Menu Midi"
              }
            ],
            "name": "La Bella Italia"
          },
          "success": true,
          "timestamp": "2026-03-21T12:00:00.000Z"
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.address": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.cuisine": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.data.menus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data.menus[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.menus[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.data.menus[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSX",
                  "match": "datetime"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
