generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CuisineType {
  FRANCAISE
  ITALIENNE
  JAPONAISE
  CHINOISE
  INDIENNE
  MEXICAINE
  AMERICAINE
  THAILANDAISE
  LIBANAISE
  AUTRE
}

model Restaurant {
  id           String      @id @default(uuid())
  name         String
  cuisineType  CuisineType @map("cuisine")
  street       String
  city         String
  zipCode      String      @map("zip_code")
  country      String
  rating       Float       @default(0)
  averagePrice Float       @map("average_price")
  phoneNumber  String?     @map("phone_number")
  countryCode  String?     @map("country_code")
  localNumber  String?     @map("local_number")
  description  String?
  isOpen       Boolean     @default(true) @map("is_open")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")
  menus        Menu[]
  owner        User        @relation(fields: [ownerId], references: [id])
  ownerId      Int         @map("owner_id")

  @@index([cuisineType], map: "idx_restaurants_cuisine")
  @@index([rating(sort: Desc)], map: "idx_restaurants_rating")
  @@index([name], map: "idx_restaurants_name")
  @@index([deletedAt, createdAt(sort: Desc)], map: "idx_restaurants_deleted_created_at")
  @@index([ownerId], map: "idx_restaurants_owner_id")
  @@map("restaurants")
}

model Menu {
  id           String     @id @default(uuid())
  name         String
  description  String?
  deletedAt    DateTime?  @map("deleted_at")
  restaurantId String     @map("restaurant_id")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@index([restaurantId], map: "idx_menus_restaurant_id")
  @@map("menus")
}

model MenuItem {
  id         String     @id @default(uuid())
  name       String
  price      Decimal    @db.Decimal(10, 2)
  available  Boolean    @default(true)
  deletedAt  DateTime?  @map("deleted_at")
  menuId     String     @map("menu_id")
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  categories Category[]

  @@index([menuId], map: "idx_menu_items_menu_id")
  @@index([price], map: "idx_menu_items_price")
  @@map("menu_items")
}

model Category {
  id    String     @id @default(uuid())
  name  String     @unique
  items MenuItem[]

  @@map("categories")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("customer")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  restaurants Restaurant[]

  @@map("users")
}
